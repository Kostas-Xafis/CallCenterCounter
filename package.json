{
  "name": "callcentercounter",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev ./dist/_worker.js",
    "deploy": "astro build && wrangler deploy",
    "typecheck": "astro check && tsc --noEmit",
    "db:delete:local": "wrangler d1 execute call_center_dev --local --file=./db/delete.sql",
    "db:migrate:local": "wrangler d1 execute call_center_dev --local --file=./db/schema.sql",
    "db:delete:prod": "wrangler d1 execute call_center_prod --remote --env production --file=./db/delete.sql",
    "db:migrate:prod": "wrangler d1 execute call_center_prod --remote --env production --file=./db/schema_prod.sql",
    "hash:password": "tsx ./scripts/hash-password.ts"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@cloudflare/workers-types": "^4.20260220.0",
    "@types/bun": "^1.3.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "wrangler": "^4.6.0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "astro": "^5.18.0"
  }
}
