{
  "name": "callcentercounter",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:delete:local": "wrangler d1 execute call_center_dev --local --file=./db/delete.sql",
    "db:migrate:local": "wrangler d1 execute call_center_dev --local --file=./db/schema.sql",
    "db:migrate:prod": "wrangler d1 execute call_center_prod --file=./db/schema.sql",
    "hash:password": "tsx ./scripts/hash-password.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260220.0",
    "@types/bun": "^1.3.9",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "wrangler": "^4.6.0"
  }
}
